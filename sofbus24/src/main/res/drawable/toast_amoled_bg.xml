<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- True-black AMOLED toast surface with a subtle outline so the toast -->
    <!-- stays distinguishable when the activity behind it is also black. -->
    <solid android:color="#0F0F0F" />
    <stroke
        android:width="1dp"
        android:color="#2A2A2A" />
    <corners android:radius="14dp" />
</shape>
