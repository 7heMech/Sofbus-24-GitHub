<?xml version="1.0" encoding="utf-8"?>
<!--
  AMOLED variant of the AlertDialog window background. A single rounded
  dark-grey card with a thin white outline. We deliberately do NOT use the
  parent Theme.Holo.Dialog 9-patch background because, on a pure-black
  AMOLED screen, the 9-patch's outer shadow gradient renders as a hard
  outer rectangle around the card (the "double rectangle" artefact). A
  flat shape drawable paints exactly one card surface and nothing else.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#1F1F1F" />

    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />

    <corners android:radius="4dp" />

</shape>
