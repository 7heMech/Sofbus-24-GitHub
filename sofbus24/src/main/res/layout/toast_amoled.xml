<?xml version="1.0" encoding="utf-8"?>
<!-- Custom toast view shown while the AMOLED app theme is active. The dark -->
<!-- surface and white text keep the toast on-brand with the rest of the -->
<!-- AMOLED palette instead of inheriting the system's light toast styling. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/toast_amoled_bg"
    android:orientation="horizontal"
    android:paddingLeft="16dp"
    android:paddingTop="12dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/toast_amoled_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:textSize="14sp" />
</LinearLayout>
